{
  "paths": {
    "input": "/app/data/input",
    "output": "/app/data/output",
    "scripts": "/app/scripts"
  },
  "db_connection": {
    "host": "${DB_HOST}",
    "port": "${DB_PORT}",
    "database": "${DB_NAME}",
    "user": "${DB_USER}",
    "password": "${DB_PASSWORD}"
  },
  "queries": {
    "input_data": "SELECT * FROM input_data WHERE date = :data_date"
  },
  "logging": {
    "level": "INFO",
    "file": "/app/logs/calculator.log"
  }
}